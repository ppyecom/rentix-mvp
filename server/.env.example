# Copia este archivo a .env y ajusta los valores en tu servidor.
PORT=4000
NODE_ENV=production
# Genera uno con:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_valor_largo_y_aleatorio

# Base de datos Turso (SQLite en la nube, persistente y gratis).
# Obtén estos valores en https://turso.tech (ver README).
# Si los dejas vacíos, se usa un archivo local (server/rentix.db).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
